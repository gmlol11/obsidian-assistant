# Dedicated environment for Vault Worker. Do not add Telegram, Gateway, or LLM secrets.
OBSIDIAN_ASSISTANT_ENV=production
OBSIDIAN_LOG_LEVEL=INFO
OBSIDIAN_VAULT_PATH=/Users/obsidian/Documents/Obsidian
OBSIDIAN_RUNTIME_PATH=/Users/obsidian/Library/Application Support/obsidian-assistant
OBSIDIAN_INBOX_DIR=00 Inbox
OBSIDIAN_ALLOWED_WRITE_DIRS=00 Inbox

# Keep true through the first end-to-end verification.
OBSIDIAN_DRY_RUN=true
OBSIDIAN_QUEUE_MAX_ATTEMPTS=3
OBSIDIAN_QUEUE_LEASE_SECONDS=300
