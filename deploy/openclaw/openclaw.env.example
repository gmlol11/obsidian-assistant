# Copy to ~/.openclaw/.env on the target Mac mini and chmod 600.
# Never commit the populated file.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
OPENCLAW_GATEWAY_TOKEN=

# Non-secret absolute paths used by the capture plugin.
OBSIDIAN_ASSISTANT_COMMAND=/Users/obsidian/services/obsidian-assistant/.venv/bin/obsidian-assistant
OBSIDIAN_WORKER_ENV_FILE=/Users/obsidian/services/obsidian-assistant/worker.env
