# Runtime
OBSIDIAN_ASSISTANT_ENV=development
OBSIDIAN_LOG_LEVEL=INFO

# Local Python path. Keep the fixture value until you intentionally select a vault.
OBSIDIAN_VAULT_PATH=./tests/fixtures/vault
OBSIDIAN_INBOX_DIR=00 Inbox
OBSIDIAN_ALLOWED_WRITE_DIRS=00 Inbox
OBSIDIAN_DRY_RUN=true

# Docker bind mount source. The container always sees the vault as /vault.
HOST_VAULT_PATH=./tests/fixtures/vault

# Integrations are intentionally blank until their roadmap stages are implemented.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
OPENAI_API_KEY=
LLM_PROVIDER=disabled
